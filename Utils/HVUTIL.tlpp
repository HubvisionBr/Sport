/*----------------------------------------------------------------------*
| User: F3PESQ (_Tipo, _Operacao)                                       |
|-----------------------------------------------------------------------|
|  Utilidade:                                                           |
|	a função é chamada ao se localizar no campo e acionar a tecla 'F3'. |
|   Esta tecla chamará a consulta específica do campo. Será passado:    |
|     TIPO: 'T0', 'T2', etc...                                          |
|     ROTINA: Movimentação Bancária, Documento de Entrada, etc...       |
|     OPERAÇÃO: 'CREDITO' ou 'DEBITO', apenas para os códigos T.        |
|                                                                       |
|  Após ser chamada esta função, os campos retornarão valor de acordo   |
|  com Query estabelecida pela Regra CAM.                               |
*----------------------------------------------------------------------*/

User Function F3PESQ(cAlias,aIndex,xRet)

Local nX 
Local cWhere := ""
PUBLIC  aRet       := {}
Private cAliF3     := GetNextAlias()
PRIVATE cMarca     := GetMark()
PRIVATE lInverte   := .F.
Private cCondMarca := ""
Private _lRet      := .F.
Private _aDados    := {}
Private cPesq      := &(ReadVar()) + Space(100)
Private cCombo     := SPACE(50)

SetKey( K_CTRL_0,  {|| Ctrl0(), cPesq := SPACE(100) } )
SetKey( K_CTRL_1,  {|| Ctrl1(cAlias,aIndex), cPesq := SPACE(100) } )
SetKey( K_CTRL_2,  {||oDlg1:End(),_lRet:=.T.} )
SetKey( K_CTRL_3,  {||oDlg1:End(),_lRet:=.F.} )

cDesc := FWSX2Util():GetFile(cAlias)

/*---------------------------------------------------------------------------
## Declaração de Variaveis Private dos Objetos                             ##
---------------------------------------------------------------------------*/
SetPrvt("oFont1","oDlg1","oSay1","oBrw1","oSBtn0","oSBtn1","oSBtn2","oGet1")

aCPO1 := {{'MARCA' ,,''}}

For nX := 1 to Len(aIndex)
	aAdd(aCPO1,{aIndex[nX],,FWSX3Util():GetDescription(aIndex[nX]) })
Next nX
		//   {'COD'   ,,'Codigo'},;
		//   {'DESC1' ,,'Descricao'}}


// IF "SB1" $ cAlias
//     aAdd(aCPO1,{'APLIC' ,,'Aplicação'})
// Endif

 // Criação da tabela temporária
  aCampos := {{"MARCA","C",002,0}}

For nX := 1 to Len(aIndex)
	aAdd(aCampos,{aIndex[nX],FWSX3Util():GetFieldType(aIndex[nX]) ,FWSX3Util():GetFieldStruct(aIndex[nX])[3],FWSX3Util():GetFieldStruct(aIndex[nX])[4] })
Next nX

// IF "SB1" $ cAlias
//     aAdd(aCampos,{"APLIC","C",150,0})
// Endif

 // --- Criar tabela temporária
 // ---------------------------
  oTempTable := FWTemporaryTable():New(cAliF3)
  oTemptable:SetFields(aCampos)
//   oTempTable:AddIndex("01",{"COD"  ,"DESC1"})
//   oTempTable:AddIndex("02",{"DESC1","COD"})
For nX := 1 to Len(aIndex)
	oTempTable:AddIndex(StrZero(nX,2),{aIndex[nX]})
Next nX

	If !Empty(Alltrim(cPesq))
		cWhere := "("
		For nX := 1 to Len(aIndex)
			cWhere += "TRIM("+Alltrim(aIndex[nX]) + ") LIKE '"+Alltrim(cPesq)+"' ESCAPE '\' "
			IF nX < Len(aIndex)
				cWhere += " OR "
			Endif
		Next nX
		cWhere += ")"
	Endif

  oTempTable:Create()

  MsAguarde({|| LeConsulta(cAlias,aIndex,cWhere) }, OemToAnsi("Aguarde"), OemToAnsi("Preparando Consulta..."))

  ******** JANELA DE DIALOGO PRINCIPAL **********
  oFont1 := TFont():New( "Arial Narrow",0,-13,,.F.,0,,400,.F.,.F.,,,,,, )
  oDlg1  := MSDialog():New( 141,224,412,793,"Consulta Específica                  Fonte: F3PESQ",,,.F.,,,,,,.T.,,,.T. )
  oSay1  := TSay():New( 096,008,{||"Pesquisar por:"},oDlg1,,oFont1,.F.,.F.,.F.,.T.,CLR_BLACK,CLR_WHITE,040,008)

  dbSelectArea(cAliF3)

  (cAliF3)->(dbGoTop())
  
  oMark := MsSelect():New( cAliF3,"MARCA",cCondMarca,aCPO1,@lInverte,@cMarca,{000,000,084,280},,, oDlg1 )
  
  oMark:oBrowse:Refresh(.t.)
  oMark:bMark :={|n| oDlg1:End(),_lRet:=.T. }
  oMark:oBrowse:lhasMark            := .T.
  oMark:oBrowse:lCanAllmark         := .F.
  oMark:oBrowse:acolumns[1]:lbitmap := .T.
  oMark:oBrowse:acolumns[1]:lnolite := .T.
  oMark:oBrowse:acolumns[1]:ledit   := .F.

//   oSBtn0 := SButton():New( 112,120,3,{|| MsAguarde({|| LeConsulta(cAlias) }, OemToAnsi("Aguarde"), OemToAnsi("Removendo filtros..."), cPesq := SPACE(100)) },oDlg1,,"", )
  oSBtn0 := TButton():New( 112,114, "Limpar (Ctrl+1)",oDlg1,{|| MsAguarde({|| LeConsulta(cAlias,aIndex) }, OemToAnsi("Aguarde"), OemToAnsi("Removendo filtros..."), cPesq := SPACE(100)) }, 42,10,,,.F.,.T.,.F.,,.F.,,,.F. )
//   oSBtn1 := SButton():New( 112,160,1,{||oDlg1:End(),_lRet:=.T.},oDlg1,,"", )
  oSBtn1 := TButton():New( 112,160, "OK (Ctrl+2)",oDlg1,{||oDlg1:End(),_lRet:=.T.}, 42,10,,,.F.,.T.,.F.,,.F.,,,.F. )
//   oSBtn2 := SButton():New( 112,196,2,{||oDlg1:End(),_lRet:=.F.},oDlg1,,"", )
  oSBtn2 := TButton():New( 112,206, "Cancelar (Ctrl+3)",oDlg1,{||oDlg1:End(),_lRet:=.F.}, 42,10,,,.F.,.T.,.F.,,.F.,,,.F. )
//   oCBox1 := TComboBox():New( 085,052,{|u| If( Pcount()>0, cCombo:= u, cCombo)},{"1-Descricao","2-Codigo"},072,010,oDlg1,,,,CLR_BLACK,CLR_WHITE,.T.,,"",,,,,,,"cCombo")
  oGet1  := TGet():New( 096,052,{|u| If(PCount()>0,cPesq:=u,cPesq)},oDlg1,152,008,'@!',{|u| U_GETPESQ(cAlias,aIndex,cCombo)},CLR_BLACK,CLR_WHITE,,,,.T.,"",,,.F.,.F.,,.F.,.F.,"","cPesq",,)
  oGet1:cPlaceHold := "Aperte CTRL+0 para focar"

  oGet1:SetFocus()
  oMark:oBrowse:Refresh(.t.)
  oDlg1:Activate(,,,.T.)


 IF _lRet 
	For nX := 1 to Len(xRet)
		aAdd(aRet,&("(cAliF3)->"+xRet[nX]))
	Next nX

	IF Empty(aRet[1])
		_lRet := .F.
	Endif
 Endif

  dbSelectArea(cAliF3)

  oTempTable:Delete()

    //Limpando Atalhos
	SetKey( K_CTRL_0,  Nil )
	SetKey( K_CTRL_1,  Nil )
	SetKey( K_CTRL_2,  Nil )
	SetKey( K_CTRL_3,  Nil )
Return _lRet

//-------------------------------------------------------------------
/*/{Protheus.doc} LeConsulta()
  Ler a Consulta.
  						  
  @Parametro: _Tipo     = Tipo da pesquisa
              -Operacao = Operação a realizar
  @author Desconhecido
  @version P12.1.17
  @since  16/12/2019	
/*/
//-------------------------------------------------------------------
Static Function LeConsulta(cAlias,aIndex,cWhere)
    Local cQuery := " "
    Local cAli1 := GetNextAlias()
	Local cDB := TCGetDB()
	Local nX
    Default cWhere := ""
    
    //Limpa os dados da tabela temporária
    oTempTable:Zap()

	// Query para preparar os dados.
	IF "ORACLE" $ cDb
		cQuery := " SELECT * FROM "+RETSQLNAME(cAlias)
		cQuery += " WHERE D_E_L_E_T_ <> '*' "
		IF !Empty(cWhere)
			cQuery += " AND " + cWhere
		Endif
		cQuery += " AND ROWNUM <= 100"
	Else
		cQuery := " SELECT TOP 100 * FROM "+RETSQLNAME(cAlias)
		cQuery += " WHERE D_E_L_E_T_ <> '*' "
		IF !Empty(cWhere)
			cQuery += " AND " + cWhere
		Endif
	Endif

	MpSysOpenQuery(cQuery,cAli1)
	Dbselectarea(cAli1)
	(cAli1)->(DBGOTOP())

	if (cAli1)->(Eof())
        Reclock(cAliF3,.T.)
        For nX := 1 to Len(aIndex)
			cTipo := FWSX3Util():GetFieldType(aIndex[nX])
			IF cTipo == "D"
				Replace &("(cAliF3)->"+aIndex[nX])   with CtoD("")
			ElseIf cTipo == "C"
				Replace &("(cAliF3)->"+aIndex[nX])   with Space(FWSX3Util():GetFieldStruct(aIndex[nX])[3])
			ElseIf cTipo == "N"
				Replace &("(cAliF3)->"+aIndex[nX])   with 0
			Endif
			(cAliF3)->(MsUnlock())
		Next nX
        (cAliF3)->(MsUnlock())
	endif

	/* Fim da alteração */
	While !(cAli1)->(Eof())
		
        Reclock(cAliF3,.T.)
		For nX := 1 to Len(aIndex)
			cTipo := FWSX3Util():GetFieldType(aIndex[nX])
			IF cTipo == "D"
				Replace &("(cAliF3)->"+aIndex[nX])   with StoD(&("(cAli1)->"+aIndex[nX]))
			Else
				Replace &("(cAliF3)->"+aIndex[nX])   with &("(cAli1)->"+aIndex[nX])
			EndIf
			(cAliF3)->(MsUnlock())
		Next nX

		(cAli1)->(dbskip())
	EndDo

	dbSelectarea(cAli1)
	(cAli1)->(dbCloseArea())
  
Return

//-------------------------------------------------------------------
/*/{Protheus.doc} F3PESQ()
  Localizar a chave digitada.
  						  
  @Parametro: cCombo = Lista de Campos de pesquisa
  @author Desconhecido
  @version P12.1.17
  @since  16/12/2019	
/*/
//-------------------------------------------------------------------
User Function GetPesq(cAlias,aIndex,cCombo)
	Local nX
	Local cWhere := ""

	IF !Empty(Alltrim(cPesq))
		cWhere := "("
		For nX := 1 to Len(aIndex)
			cWhere += "TRIM("+Alltrim(aIndex[nX]) + ") LIKE '"+Alltrim(cPesq)+"' ESCAPE '\' "
			IF nX < Len(aIndex)
				cWhere += " OR "
			Endif
		Next nX
		cWhere += ")"
	Endif

	//" (B1_COD LIKE '"+Alltrim(cPesq)+"' OR  B1_DESC LIKE '"+cPesq+"')")

    MsAguarde({|| LeConsulta(cAlias,aIndex,cWhere)}, OemToAnsi("Aguarde"), OemToAnsi("Filtrando dados..."))
    
	oMark:oBrowse:Refresh(.t.)

Return .T.

Static Function Ctrl1(cAlias,aIndex)

MsAguarde({|| LeConsulta(cAlias,aIndex) }, OemToAnsi("Aguarde"), OemToAnsi("Removendo filtros..."))

Return

Static Function Ctrl0()

oGet1:SetFocus()

Return
